# ---- parse_address: country canonicalization ----

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('529 Main Street, Boston, MA 021') as pa);
----
529	Main Street	NULL	529 Main Street	Boston	MA	021	NULL	US

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('529 Main Street, Boston, MA 021, France') as pa);
----
529	Main Street	NULL	529 Main Street	Boston	MA	021	NULL	FR

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('100 Peachtree St, Atlanta, Georgia') as pa);
----
100	Peachtree St	NULL	100 Peachtree St	Atlanta	GA	NULL	NULL	US

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('212 n 3rd ave, Minneapolis, mn 55401, USA') as pa);
----
212	n 3rd ave	NULL	212 n 3rd ave	Minneapolis	MN	55401	NULL	US

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('26 Court Street, Boston, Massachusetts 02109, FR') as pa);
----
26	Court Street	NULL	26 Court Street	Boston	MA	02109	NULL	FR

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('26 Court Street, Boston, MA 02109, Rear') as pa);
----
26	Court Street, Boston, MA 02109	NULL	26 Court Street, Boston, MA 02109	Rear	NULL	NULL	NULL	US

