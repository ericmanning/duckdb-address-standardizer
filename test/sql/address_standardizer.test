# name: test/sql/address_standardizer.test
# description: Test parse_address function
# group: [address_standardizer]

require address_standardizer

# ---- parse_address: empty/blank input edge cases ----

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('') as pa);
----
NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address(' ') as pa);
----
NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address(' , ,  ') as pa);
----
NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL

# ---- parse_address basic tests ----

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('123 Main Street, Kansas City, MO 45678') as pa);
----
123	Main Street	NULL	123 Main Street	Kansas City	MO	45678	NULL	US

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('385 Landgrove Rd  Landgrove VT 05148') as pa);
----
385	Landgrove Rd	NULL	385 Landgrove Rd	Landgrove	VT	05148	NULL	US

query IIIIIIIII
SELECT pa.* FROM (SELECT parse_address('university ave w @ main st, saint paul, mn, 55104-3431') as pa);
----
NULL	university ave w	main st	NULL	saint paul	MN	55104	3431	US

# ---- parse_address: street type + directionals (no comma) ----

query IIIIIIIII
