# ---- Test 1: Basic invocation returns valid JSON with expected structure ----
# Verify the function returns a string that can be parsed as JSON

query I
SELECT json_array_length(json(d)->'rules'->0->'rule_tokens')
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '123 Main Street', 'Kansas City, MO 45678') as d);
----
3

# ---- Test 2: rule_tokens for first rule of 123 Main Street ----

query IIIII
SELECT je->>'pos' AS pos,
       je->>'input-word' AS input_word,
       je->>'input-token' AS input_token,
       je->>'mapped-word' AS output_word,
       je->>'output-token' AS output_token
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '123 Main Street', 'Kansas City, MO 45678') as d),
     unnest(from_json(json(d)->'rules'->0->'rule_tokens', '["json"]')) AS t(je)
ORDER BY CAST(je->>'pos' AS INTEGER);
----
0	123	NUMBER	123	HOUSE
1	MAIN	WORD	MAIN	STREET
2	STREET	TYPE	STREET	SUFTYP

# ---- Test 3: Count rules for 10-20 DORRANCE ST (4-arg) ----

query I
SELECT json_array_length(json(d)->'rules')
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '10-20 DORRANCE ST PROVIDENCE RI') as d);
----
6

# ---- Test 4: #5299a num_rules, num_input_tokens, best_score ----

query III
SELECT json_array_length(json(d)->'rules') AS num_rules,
       json_array_length(json(d)->'input_tokens') AS num_input_tokens,
       json(d)->'rules'->0->>'raw_score' AS best_score
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '1 Timepiece Point', 'Boston, MA, 02220') as d);
----
5	4	0.9025

# ---- Test 5: #2978c num_rules, num_input_tokens, best_score (4-arg) ----

query III
SELECT json_array_length(json(d)->'rules') AS num_rules,
       json_array_length(json(d)->'input_tokens') AS num_input_tokens,
       json(d)->'rules'->0->>'raw_score' AS best_score
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '10-20 DORRANCE ST, PROVIDENCE, RI') as d);
----
6	5	0.751875

# ---- Test 6: #5299b score (4-arg) ----

query III
SELECT json_array_length(json(d)->'rules') AS num_rules,
       json_array_length(json(d)->'input_tokens') AS num_input_tokens,
       json(d)->'rules'->0->>'score' AS best_score
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '50 Gold Piece Drive, Boston, MA, 02020') as d);
----
3	6	0.9025

# ---- Test 7: Filter input_tokens by position for ambiguous word ----

query IIII
SELECT je->>'pos' AS pos,
       je->>'word' AS word,
       je->>'token' AS token,
       je->>'stdword' AS stdword
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '50 Gold Piece Drive, Boston, MA, 02020') as d),
     unnest(from_json(json(d)->'input_tokens', '["json"]')) AS t(je)
WHERE CAST(je->>'pos' AS INTEGER) = 2
ORDER BY pos, stdword, word, token;
----
2	PIECE	UNITH	PIECE
2	PIECE	UNITT	PIECE
2	PIECE	WORD	PIECE

# ---- Test 8: Extract score, rule_type, rule_weight, rule_string, rule_stub for all rules ----

query IIIII
SELECT r->>'score' AS score,
       r->>'rule_type' AS rule_type,
       r->>'rule_weight' AS rule_weight,
       r->>'rule_string' AS rule,
       r->>'rule_stub_string' AS rule_stub
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '25 Prince Street, NC 09985') as d),
     unnest(from_json(json(d)->'rules', '["json"]')) AS t(r)
ORDER BY CAST(r->>'score' AS DOUBLE) DESC;
----
0.9025	MICRO	16	0 1 2 -1 1 5 6 -1 1 16	0 1 2 -1 1 5 6 -1 %
0.791875	MICRO	16	0 1 2 -1 1 5 6 -1 1 16	0 1 2 -1 1 5 6 -1 %
0.66125	NULL	NULL	NULL	0 1 2 -1 1 5 5 -1 %

# ---- Test 9: Verify stdaddr section in JSON ----

query II
SELECT json(d)->'stdaddr'->>'house_num' AS house_num,
       json(d)->'stdaddr'->>'name' AS name
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '123 Main Street', 'Kansas City, MO 45678') as d);
----
123	MAIN

# ---- Test 10: Verify micro/macro in JSON ----

query II
SELECT json(d)->>'micro' AS micro,
       json(d)->>'macro' AS macro
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '123 Main Street', 'Kansas City, MO 45678') as d);
----
123 Main Street	Kansas City, MO 45678

# ---- Test 11: state_only_macro 5-arg debug ----

query III
SELECT json(d)->'stdaddr'->>'city' AS city,
       json(d)->'stdaddr'->>'state' AS state,
       json(d)->'stdaddr'->>'postcode' AS postcode
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '25 Prince Street', 'NC 09985') as d);
----
NULL	NORTH CAROLINA	09985

# ---- Test 12: Large address - count tokens and rules ----

query IIIII
SELECT json_array_length(json(d)->'input_tokens') AS num_input_tokens,
       json_array_length(json(d)->'rules') AS num_rules,
       (SELECT count(*) FROM unnest(from_json(json(d)->'rules', '["json"]')) AS t(r) WHERE r->>'rule_stub_string' IS NULL) AS skipped_rule_lookups,
       (SELECT count(*) FROM unnest(from_json(json(d)->'rules', '["json"]')) AS t(r) WHERE r->>'rule_id' IS NULL) AS null_rule_ids,
       (SELECT count(*) FROM unnest(from_json(json(d)->'rules', '["json"]')) AS t(r) WHERE r->>'rule_id' = '-1') AS unmatched_rule_rows
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '123 MAIN STREET APARTMENT 1 BUILDING A FLOOR 2 UNIT 3 ROOM 4', 'BOSTON MA 02101') as d);
----
17	6	0	0	6

# ---- Test 13: Verify NONE output tokens and no INVALID tokens ----

query II
SELECT
    (SELECT count(*) FROM unnest(from_json(json(d)->'rules', '["json"]')) AS t(r), unnest(from_json(r->'rule_tokens', '["json"]')) AS t2(je) WHERE je->>'output-token' = 'NONE') AS none_output_tokens,
    (SELECT count(*) FROM unnest(from_json(json(d)->'rules', '["json"]')) AS t(r), unnest(from_json(r->'rule_tokens', '["json"]')) AS t2(je) WHERE je->>'output-token' = 'INVALID') AS invalid_output_tokens
FROM (SELECT debug_standardize_address('us_lex', 'us_gaz', 'us_rules', '123 MAIN STREET APARTMENT 1 BUILDING A FLOOR 2 UNIT 3 ROOM 4', 'BOSTON MA 02101') as d);
----
2	0
